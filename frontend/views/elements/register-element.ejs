<div class="min-vh-100 d-flex align-items-center justify-content-center" style="background-color: #2A1F1A;">
    <div class="card shadow border-0" style="width: 100%; max-width: 420px;">
        <div class="card-body p-5">

            <h4 class="text-center fw-bold mb-2">Registrati su ByteNote</h4>
            <p class="text-center text-muted mb-4">Inserisci i tuoi dati per registrarti</p>

            <% if (locals.errore) { %>
                <div class="alert alert-danger"><%= errore %></div>
            <% } %>

            <form action="/register" method="POST">
                <div class="mb-3">
                    <label for="name" class="form-label fw-semibold">Inserici il tuo nome</label>
                    <input type="text" id="name" name="name" class="form-control form-control-lg" placeholder="Inserisci il tuo nome" required>
                </div>

                <div class="mb-3">
                    <label for="email" class="form-label fw-semibold">Inserisci la tua email</label>
                    <input type="email" id="email" name="email" class="form-control form-control-lg" placeholder="Inserisci la tua email" required>
                </div>

                <div class="mb-4">
                    <label for="password" class="form-label fw-semibold">Inserisci la tua password</label>
                    <input type="password" id="password" name="password" class="form-control form-control-lg" placeholder="Inserisci la tua passowrd" required>
                </div>

                <div class="mb-4">
                    <label for="passowrd" class="form-label fw-semibold">Conferma la password scelta</label>
                    <input type="password" id="password2" name="password2" class="form-control form-control-lg" placeholder="Conferma la tua password" required>
                </div>

                <div class="d-grid mb-3">
                    <button type="submit" class="btn btn-lg fw-semibold" style="background-color: #FF4A00; color: white;">Registrati</button>
                </div>

                <div class="text-center">
                    <span class="text-muted">Hai già un account? </span>
                    <a href="/login" style="color: #FF4A00;">Accedi ora</a>
                </div>
            </form>

        </div>
    </div>
</div>