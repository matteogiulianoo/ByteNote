<div class="d-flex flex-column min-vh-100" style="background-color: #F4F4F4;">

    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between px-4 py-3 border-bottom shadow-sm" style="background-color: #654b40;">
    
        <!-- Navbar -->
        <ul class="nav nav-tabs border-0 gap-2">
            <li class="nav-item">
                <a class="nav-link fw-semibold" style="color: #ffffff; border-bottom: 2px solid #FF4A00;" href="#news" data-section="news">Notizie</a>
            </li>
            <li class="nav-item">
                <a class="nav-link fw-semibold" style="color: rgba(255,255,255,0.6);" href="#spazi" data-section="spazi">I miei Spazi</a>
            </li>
        </ul>

        <!-- Bottoni -->
        <div class="d-flex gap-2">
            <a href="/settings-user" class="btn fw-semibold" style="border: 1px solid rgba(255,255,255,0.4); color: white;">
                Impostazioni
            </a>
            <form action="/logout" method="POST" class="m-0">
                <button type="submit" class="btn fw-semibold" style="background-color: #FF4A00; color: white;">
                    ➜]
                </button>
            </form>
        </div>

    </div>

    <!-- Finestra Principale -->
    <div class="flex-grow-1 p-4">

        <!-- Notizie -->
        <div id="section-news">
            <h5 class="fw-bold mb-3">Notizie</h5>
            <div class="d-flex flex-wrap gap-3">
                <% news.forEach(articolo => { %>
                    <div class="card border-0 shadow-sm" style="width: 18rem;">
                        <% if (articolo.immagine) { %>
                            <img src="<%= articolo.immagine %>" class="card-img-top" style="height: 140px; object-fit: cover;">
                        <% } %>
                        <div class="card-body">
                            <p class="card-text"><small class="text-muted"><%= articolo.pubDate %></small></p>
                            <h6 class="card-title fw-semibold"><%= articolo.title %></h6>
                            <a href="<%= articolo.link %>" target="_blank" style="color: #FF4A00;">Leggi articolo →</a>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>

        <!-- Spazi -->
        <div id="section-spazi" class="d-none">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold m-0">I miei Spazi</h5>

                <form action="/crea" method="POST" class="d-flex gap-2 align-items-center">
                    <input type="text" name="nome" class="form-control form-control-sm" placeholder="Nome Spazio" required>
                    <input type="text" name="descr" class="form-control form-control-sm" placeholder="Descrizione Spazio" required>
                    <button type="submit" class="btn btn-sm fw-semibold text-nowrap" style="background-color: #FF4A00; color: white;">
                        Crea nuovo spazio
                    </button>
                </form>
            </div>
            <div class="d-flex justify-content-between align-items-center mb-3">
                <p class="m-0">Benvenuto nei tuoi spazi</p>
                <form action="/nuovanota" method="POST" class="d-flex gap-2 align-items-center">
                    <input type="text" name="nomeNota" class="form-control form-control-sm" placeholder="Nome Nuova Nota" required>
                    <select name="spazioNota" class="form-select form-select-sm" required>
                        <option value="" disabled selected>Scegli uno spazio</option>
                        <% spazi.forEach(spazio => { %>
                            <option value="<%= spazio.id %>"><%= spazio.nome %></option>
                        <% }) %>
                    </select>
                    <button type="submit" class="btn btn-sm fw-semibold text-nowrap" style="background-color: #FF4A00; color: white;">
                        Crea nuova nota
                    </button>
                </form>
            </div>

            <% if (spazi.length === 0) { %>
                <p class="text-muted">Non hai ancora creato nessuno spazio.</p>
            <% } else { %>
                <div class="d-flex flex-wrap gap-3">
                    <% spazi.forEach(spazio => { %>
                        <div class="card" style="width: 18rem;">
                            <div class="card-body">
                                <h5 class="card-title"><%= spazio.nome %></h5>
                                <p class="card-text text-muted"><%= spazio.descr ?? 'Nessuna descrizione' %></p>
                                <small class="text-muted">Creato il <%= new Date(spazio.creation_date).toLocaleDateString('it-IT') %></small> <br><br>
                            </div>
                            <ul class="list-group list-group-flush">
                                <% if (spazio.note && spazio.note.length > 0) { %>
                                    <% spazio.note.forEach(nota => { %>
                                        <li class="list-group-item"><a href="/nota/<%= nota.id %>"><%= nota.title %></a></li>
                                    <% }) %>
                                <% } else { %>
                                    <li class="list-group-item text-muted">Nessuna nota</li>
                                <% } %>
                            </ul>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </div>

    </div>

</div>

<script>
    // Da qua si possono caricare le varie sezioni!
    document.querySelectorAll('[data-section]').forEach(tab => {
        tab.addEventListener('click', (e) => {
            e.preventDefault()
            const target = tab.getAttribute('data-section')

            document.querySelectorAll('[id^="section-"]').forEach(s => s.classList.add('d-none'))
            document.getElementById('section-' + target).classList.remove('d-none')

            document.querySelectorAll('[data-section]').forEach(t => {
                t.style.color = 'rgba(255,255,255,0.6)'
                t.style.borderBottom = 'none'
            })

            tab.style.color = '#ffffff'
            tab.style.borderBottom = '2px solid #FF4A00'
        })
    })
</script>