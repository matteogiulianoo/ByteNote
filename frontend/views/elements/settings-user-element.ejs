            <div class="card-body p-5">

                <h4 class="text-center fw-bold mb-2">Impostazioni Utente</h4>
                <p class="text-center text-muted mb-4" style="font-size: 14px;">Queste sono le impostazioni dove potrai gestire i tuoi dati/i tuoi spazi</p>

                <hr>

                <h6 class="text-center fw-bold mb-4">Gestisci Dati Utente</h6>

                <hr>

                <h6 class="text-center fw-bold mb-4">Gestisci i tuoi spazi</h6>
                <p class="text-center text-muted mb-4" style="font-size: 14px">Modifica il nome di uno spazio</p>
                <p class="text-center text-muted mb-4" style="font-size: 14px">Elimina uno spazio</p>

                <% if (locals.errore) { %>
                    <div class="alert alert-danger"><%= errore %></div>
                <% } %>

