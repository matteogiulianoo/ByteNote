<div class="d-flex flex-column min-vh-100" style="background-color: #F4F4F4;">

    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between px-4 py-3 border-bottom shadow-sm" style="background-color: #654b40;">
    
        <!-- Navbar -->
        <ul class="nav nav-tabs border-0 gap-2">
            <form action="/salvanota" method="POST" class="m-0" onsubmit="save()">
                <input type="hidden" name="context" id="hiddenContext">
                <button type="submit" class="btn fw-semibold" style="background-color: #15960e; color: white;">
                    Salva
                </button>
            </form>
            <form action="/chiudinota" method="POST" class="m-0">
                <button type="submit" class="btn fw-semibold" style="background-color: #FF4A00; color: white;">
                    Chiudi 
                </button>
            </form>
        </ul>

        <!-- Bottoni -->
        <div class="d-flex gap-2">
            <form action="/logout" method="POST" class="m-0">
                <button type="submit" class="btn fw-semibold" style="background-color: #FF4A00; color: white;">
                    ➜]
                </button>
            </form>
        </div>

    </div>

    <div>
        <input id="title" name="title" style="font-weight: bold;" value="<%= nota.title ?? '' %>" />

        <div id="editor">
            <%= nota.context ?? '' %>
        </div>
    </div>

    <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
    <script>
        const quill = new Quill('#editor', { theme: 'snow' });

        function save() {
            const context = quill.root.innerHTML;
            document.getElementById('hiddenContext').value = context;

            const title = document.getElementById('title').value;
            document.getElementById('hiddenTitle').value = title;
        }
    </script>
</div>