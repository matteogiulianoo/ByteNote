<div class="d-flex flex-column min-vh-100" style="background-color: #F4F4F4;">

    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between px-4 border-bottom position-relative" style="background-color: #2A1F1A; height: 60px;">
    
        <!-- Bottoni -->
        <div class="d-flex gap-2">
            <!-- Bottone per interagire con AI -->
            <button onclick="askAI()" class="nav-link fw-medium px-4 py-1 rounded-pill" style="color: #FF7A40; background-color: rgba(255,74,0,0.15);">
                🧠
            </button>
        </div>

        <!-- Navbar -->
        <ul class="nav position-absolute start-50 translate-middle-x">
            <li class="nav-item">
                <form action="/salvanota" method="POST" class="m-0" onsubmit="save()">
                    <!-- Con questi input nascosti prendiamo i dati che ci servono per modificare la nota -->
                    <input type="hidden" name="context" id="hiddenContext">
                    <input type="hidden" name="title" id="hiddenTitle">
                    <input type="hidden" name="note_id" value="<%= nota.id %>">
                    <button type="submit" class="nav-link fw-medium px-4 py-1 rounded-pill" style="color: #FF7A40; background-color: rgba(255,74,0,0.15);">
                        Salva
                    </button>
                </form>
            </li>
            <li class="nav-item">
                <form action="/chiudinota" method="GET" class="m-0">
                    <button type="submit" class="nav-link fw-medium px-4 py-1 rounded-pill" style="color: rgba(255,255,255,0.45);">
                        Chiudi 
                    </button>
                </form>
            </li>
        </ul>

        <!-- Bottoni -->
        <div class="d-flex gap-2">
            <form action="/eliminanota" method="POST" class="m-0">
                <input type="hidden" name="note_id" value="<%= nota.id %>">
                <button type="submit" class="btn btn-sm fw-medium" style="border: 0.5px solid rgba(255,255,255,0.25); color: rgba(255,255,255,0.7);">
                    Elimina Nota
                </button>
            </form>
        </div>
        
    </div>

    <div>
        <div class="d-flex gap-2 m-2">
            <input id="title" name="title" style="font-weight: bold; background: transparent; fill: none; border: none;" value="<%= nota.title ?? '' %>" />
            
            <div class="d-flex flex-wrap gap-1">
                <% tag.forEach(tagg => { %>
                    <div class="form-check">
                        <input 
                            class="form-check-input" 
                            type="checkbox" 
                            value="<%= tagg.id %>"
                            data-note-id="<%= nota.id %>"
                            <%= tagInNota.some(t => t.tag_id === tagg.id) ? 'checked' : '' %>
                            onchange="changeTag(this)"
                        >
                        <label class="form-check-label"><%= tagg.name %></label>
                    </div>
                <% }) %>
            </div>
        </div>

        <div id="editor">
            <%= nota.context ?? '' %>
        </div>
    </div>

    <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
    <script>
        const quill = new Quill('#editor', { theme: 'snow' });

        function save() {
            const context = quill.getText();
            document.getElementById('hiddenContext').value = context;

            const title = document.getElementById('title').value;
            document.getElementById('hiddenTitle').value = title;
        }


        /**
         * Domanda all'AI coe sistemare gli appunti
         */
        async function askAI() {
            const context = quill.getText();

            const response = await fetch('/ai', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({ context })
            })

            const data = await response.json()

            if (!response.ok) {
                alert(data.errore || "Errore durante la richiesta AI")
                return
            }

            quill.setText(data.result);
        }

        async function changeTag(checkbox) {
            const tag_id = checkbox.value
            const note_id = checkbox.dataset.noteId
            const checked = checkbox.checked

            const response = await fetch('/cambiaTag', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({ tag_id, note_id, checked })
            })

            const data = await response.json()
            if (!response.ok) {
                alert(data.errore || "Errore durante il cambio dell'etichetta")
                checkbox.checked = !checked
            }
        }
    </script>
</div>